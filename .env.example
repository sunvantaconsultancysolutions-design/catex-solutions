# Environment Configuration for Captex Company
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000

# Admin Panel Access Key (keep this secret!)
ADMIN_KEY=captex-admin-2024-secure-key

# Email Configuration (Gmail SMTP Example)
# For Gmail: Enable "App Passwords" in Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Recipient for enquiry notifications
ADMIN_EMAIL=admin@captexcompany.com

# Optional: SendGrid (alternative to Gmail)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
